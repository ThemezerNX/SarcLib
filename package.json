{
  "name": "@themezernx/sarclib",
  "version": "2.0.1",
  "scripts": {
    "build": "rm -rf dist && pnpm run build:types && pnpm run build:esm && pnpm run build:cjs",
    "build:types": "pnpm exec tsc -p tsconfig.build.types.json",
    "build:esm": "pnpm exec tsc -p tsconfig.build.esm.json && node -e \"require('node:fs').writeFileSync('dist/esm/package.json', '{\\\"type\\\":\\\"module\\\"}\\n')\"",
    "build:cjs": "pnpm exec tsc -p tsconfig.build.cjs.json",
    "prepublishOnly": "pnpm run build",
    "publish:package": "pnpm publish --access public --no-git-checks",
    "test": "pnpm exec tsx --test tests/**/*.spec.ts",
    "docs": "typedoc --tsconfig tsconfig.lib.json",
    "lint": "eslint . --ext .ts"
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "tsx": "^4.20.6",
    "typedoc": "^0.26.11",
    "typescript": "^5.9.3"
  },
  "sideEffects": false
}

